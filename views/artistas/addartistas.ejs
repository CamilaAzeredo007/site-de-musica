<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/artistas/lst" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Novo Artista/Banda</h2>
            
            <form method="post">
                <div class="form-group">
                    <label for="nome">Nome do Artista/Banda *</label>
                    <input 
                        type="text" 
                        id="nome" 
                        name="nome" 
                        
                    >
                </div>

                <div class="form-group">
                    <label for="pais">País *</label>
                    <input 
                        type="textarea" 
                        id="pais" 
                        name="pais" 
                    >
                </div>

                <div class="form-group">
                    <label for="anoInicio">Ano Início *</label>
                    <input 
                        type="textarea" 
                        id="anoInicio" 
                        name="anoInicio" 
                    >
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/artistas/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>