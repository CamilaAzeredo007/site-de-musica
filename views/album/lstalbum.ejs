<%- include('../cabecalho.ejs')%>

    <main class="container">
        <div class="page-header">
            <h2>Lista de Álbuns</h2>
            <a href="/album/add" class="btn btn-success">+ Novo Álbum</a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Artista</th>
                        <th>Descrição</th>
                        <th>Ano de Lançamento</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <%album.forEach(album => {%>
                    <tr>
                        <td><%=album.nome%></td>
                        <td><%=album.artista%></td>
                        <td><%=album.descricao%></td>
                        <td><%=album.anoLanc%></td>
                        <td><a href="/album/del/<%=album.id%>" class="link">Excluir</a>
                        <a href="/album/edt/<%=album.id%>" class="link">Editar</a></td>
                    </tr>
                    <%})%>
                  
                </tbody>
            </table>
        </div>
    </main>

<%- include('../rodape.ejs')%>
