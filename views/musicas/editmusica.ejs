<%-include('../cabecalho.ejs')%>
 <header>
        <h3>Editar Música</h3>
      </header>
      <div class="content">
        <form id="form-instrumento" method="post" autocomplete="off" >
          <div class="grid">
            <div>
              <label for="nome">ID da Música</label>
              <input id="id" value="<%=musica.id%>" name="id" type="text" placeholder="Ex:Gope" required>
            </div>
            <div>
              <label for="nome">Nome da Música</label>
              <input id="nome" value="<%=musica.titulo%>" name="titulo" type="text" placeholder="Ex:Gope" required>
            </div>
            <div>
              <label for="nome">Artista da Música</label>
              <input id="nome" value="<%=musica.artista%>" name="artista" type="text" placeholder="Ex:Gope" required>
            </div>
            <div>
              <label for="nome">Gênero da Música</label>
              <input id="nome" value="<%=musica.genero%>" name="genero" type="text" placeholder="Ex:Gope" required>
            </div>
            <div>
              <label for="nome">Ano da Música</label>
              <input id="nome" value="<%=musica.ano%>" name="ano" type="text" placeholder="Ex:Gope" required>
            </div>
             <div>
              <label for="nome">Álbum da Música</label>
              <input id="nome" value="<%=musica.album%>" name="album" type="text" placeholder="Ex:Gope" required>
            </div>
             <div>
              <label for="nome">Duração da Música</label>
              <input id="nome" value="<%=musica.duracao%>" name="duracao" type="text" placeholder="Ex:Gope" required>
            </div>
           <div class="field-help">Os campos com * são obrigatórios.</div>
          <footer>
            <a type="button" class="btn ghost" id="btn-cancelar" href="/Músicas/lst">Cancelar</a>
            <button type="submit" class="btn primary">Editar Música</button>
          </footer>
        </form>
      </div>

  <%-include('../rodape.ejs')%>