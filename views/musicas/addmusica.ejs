<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/musicas/lst" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Nova Música</h2>
            
            <form method="post">
                <div class="form-group">
                    <label for="titulo">Título da Música *</label>
                    <input 
                        type="text" 
                        id="titulo" 
                        name="titulo" 
                        
                    >
                </div>

                <div class="form-group">
                    <label for="artista">Artista *</label>
                    <input 
                        type="textarea" 
                        id="artista" 
                        name="artista" 
                       
                    >
                </div>

                <div class="form-group">
                    <label for="genero">Gênero *</label>
                    <input 
                        type="textarea" 
                        id="genero" 
                        name="genero" 
                       
                    >
                </div>

                <div class="form-group">
                    <label for="ano">Ano *</label>
                    <input 
                        type="textarea" 
                        id="ano" 
                        name="ano" 
                       
                    >
                </div>

                <div class="form-group">
                    <label for="ano">Álbum *</label>
                    <input 
                        type="textarea" 
                        id="album" 
                        name="album" 
                       
                    >
                </div>

                <div class="form-group">
                    <label for="duracao">Duração *</label>
                    <input 
                        type="textarea" 
                        id="duracao" 
                        name="duracao" 
                       
                    >
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/musicas/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>