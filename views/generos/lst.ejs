<%- include('../cabecalho.ejs')%>

    <main class="container">
        <div class="page-header">
            <h2>Lista de Gêneros</h2>
            <a href="/generos/add" class="btn btn-success">+ Novo Gênero</a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Descrição</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <%generos.forEach(genero => {%>
                    <tr>
                        <td><%=genero.nome%></td>
                        <td><%=genero.descricao%></td>
                        <td><a href="/generos/del/<%=genero.id%>" class="link">Excluir</a></td>
                    </tr>
                    <%})%>
                  
                </tbody>
            </table>
        </div>
    </main>

<%- include('../rodape.ejs')%>
